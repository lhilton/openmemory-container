# --- Postgres (default backend) ---
OM_PG_PASSWORD=change-me-please
OM_PG_USER=openmemory
OM_PG_DB=openmemory

# --- Ports ---
OM_PORT=8080
OM_DASHBOARD_PORT=3000

# --- API key (REQUIRED) ---
# The API returns 503 on protected endpoints until this is set. Send it as the
# `x-api-key` header. Generate one with: openssl rand -hex 32
OM_API_KEY=change-me-run-openssl-rand-hex-32

# --- Optional real embeddings (default is offline 'synthetic', 1536-dim) ---
# Keep the embedding dimension at 1536 to match init/01-openmemory-vectors.sql,
# or change both and reset the postgres volume (docker compose down -v).
# OM_EMBEDDINGS=openai
# OPENAI_API_KEY=sk-...
