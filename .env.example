# --- Postgres (default backend) ---
OM_PG_PASSWORD=change-me-please
OM_PG_USER=openmemory
OM_PG_DB=openmemory

# --- Ports ---
OM_PORT=8080
OM_DASHBOARD_PORT=3000

# --- Optional API key (protects the API; leave empty for no auth on first run) ---
# OM_API_KEY=

# --- Optional real embeddings (default is offline 'synthetic') ---
# OM_EMBEDDINGS=openai
# OPENAI_API_KEY=sk-...
